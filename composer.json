{
  "name": "ethersys/modelo-nettytowpimport",
  "description": "Synchronise un flux XML Modelo/Netty vers des biens immobiliers WordPress (thème Houzez) : création, mise à jour, suppression, médias, logs et DPE/GES.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "homepage": "https://github.com/ethersys/Modelo-NettyToWPImport",
  "keywords": ["wordpress", "plugin", "houzez", "immobilier", "netty", "modelo", "import", "xml"],
  "authors": [
    {
      "name": "Ethersys",
      "homepage": "https://www.ethersys.fr",
      "role": "Developer"
    }
  ],
  "support": {
    "issues": "https://github.com/ethersys/Modelo-NettyToWPImport/issues",
    "source": "https://github.com/ethersys/Modelo-NettyToWPImport"
  },
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "yoast/phpunit-polyfills": "^2.0",
    "wp-phpunit/wp-phpunit": "^6.5",
    "phpstan/phpstan": "^1.12",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcsstandards/php_codesniffer": "^3.10",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "autoload-dev": {
    "psr-4": {
      "Modelo\\NettyImport\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml",
    "lint": "phpcs --standard=.phpcs.xml modelo-nettytowpimport/",
    "analyse": "phpstan analyse --configuration phpstan.neon --memory-limit=1G"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
