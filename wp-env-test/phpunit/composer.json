{
    "name": "ethersys/ethersys-importer-for-modelo-netty-tests",
    "description": "PHPUnit test suite for ethersys-importer-for-modelo-netty",
    "type": "project",
    "require-dev": {
        "phpunit/phpunit": "^10",
        "brain/monkey": "^2",
        "squizlabs/php_codesniffer": "^3.13",
        "wp-coding-standards/wpcs": "^3.3"
    },
    "autoload-dev": {
        "psr-4": {
            "Ethersys\\NettyImport\\Tests\\": "./"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": false
        }
    }
}
